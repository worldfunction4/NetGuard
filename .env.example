# NetGuard 环境变量配置
# 复制此文件为 .env（已在 .gitignore 中，不会提交到仓库）
#
# 复制命令:
#   PowerShell: Copy-Item .env.example .env
#   CMD:        copy .env.example .env

# ── Mock 模式 ────────────────────────────────────────────
# 设为 1 可在无真实设备的情况下完整演示 NetGuard 所有功能。
# MockDriver 返回模拟的华为 / Cisco 输出，无需修改 devices.yaml。
# 真实环境去掉此变量或设为 0。
NETGUARD_MOCK=0

# ── 钉钉告警（可选）─────────────────────────────────────
# 设备巡检指标（CPU / 内存）超阈值时，通过钉钉机器人推送告警。
# 不配置则告警仅记录到日志文件，不会报错。
# DINGTALK_WEBHOOK=https://oapi.dingtalk.com/robot/send?access_token=YOUR_TOKEN

# ── 阿里云 OSS 备份同步（可选）───────────────────────────
# 配置备份完成后自动同步到阿里云 OSS，不配置则静默跳过。
# OSS_ACCESS_KEY=your_access_key_id
# OSS_SECRET_KEY=your_access_key_secret
# OSS_BUCKET=your_bucket_name
# OSS_ENDPOINT=oss-cn-hangzhou.aliyuncs.com
